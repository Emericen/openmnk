# LLM Provider (any OpenAI-compatible API)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4.1-mini

# Voice Transcription (optional — any OpenAI-compatible transcription API)
# If not set, falls back to LLM_BASE_URL and LLM_API_KEY
# TRANSCRIBE_BASE_URL=https://api.openai.com/v1
# TRANSCRIBE_API_KEY=your-api-key-here
# TRANSCRIBE_MODEL=whisper-1

# Hotkey to toggle the chat overlay.
# Common values:
# - Windows/Linux: alt, control, control_left, control_right, shift, command
# - macOS: alt (Option), control, command
# Aliases also work: ctrl, ctrl_left, ctrl_right, cmd, win, windows, option, opt
TRIGGER_KEY=alt
